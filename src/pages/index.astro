---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/navigation';
import { Tech } from '../components/tech';
import WorkExperience from '../components/experience';
import Container from '../components/container';
import FloatingGhostText from '../components/FloatingGhostText';
import { IconBrandLinkedin, IconBrandX, IconMail } from '@tabler/icons-react';

// Get the current date
const currentDate = new Date();

// Create a Date object for July 1, 2019
const date2019 = new Date('2019-07-01');

// Calculate the difference in months
let differenceInMonths =
  (currentDate.getFullYear() - date2019.getFullYear()) * 12 +
  (currentDate.getMonth() - date2019.getMonth());

// Adjust if the current date's day is before the date2019's day
if (currentDate.getDate() < date2019.getDate()) {
  differenceInMonths--;
}

// Calculate years from months
const years = Math.floor(differenceInMonths / 12);

// Calculate remaining months
const months = differenceInMonths % 12;
---

<Layout title="Home | Navneet Dabral">
  <main class="relative flex flex-col items-center overflow-hidden min-h-screen text-zinc-100 selection:bg-purple-500/30">
    
    <!-- Navigation (React Island) -->
    <Navigation client:load />

    <!-- 2026 Aurora Ambient Background Glows -->
    <div class="fixed inset-0 overflow-hidden pointer-events-none z-0">
      <div class="absolute -top-40 -left-40 w-[600px] h-[600px] bg-purple-600/20 rounded-full mix-blend-screen filter blur-[120px] animate-aurora-1"></div>
      <div class="absolute top-20 -right-20 w-[500px] h-[500px] bg-cyan-500/10 rounded-full mix-blend-screen filter blur-[100px] animate-aurora-2"></div>
      <FloatingGhostText client:load />
    </div>

    {/* Using relative z-10 for content to sit above the aurora but beneath navigation */}
    <section id="home" class="relative w-full min-h-[100dvh] overflow-hidden flex flex-col items-center justify-center pb-20 z-10 px-4">
      
      {/* Refined Display Typography Hero */}
      <div class="relative text-center animate-popIn z-10" style="animation-delay: 0.1s; animation-fill-mode: both;">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[120%] h-[200%] bg-gradient-to-r from-purple-500/20 via-cyan-500/15 to-purple-500/20 blur-[80px] -z-10 rounded-full opacity-70 pointer-events-none"></div>
        <h1 
          class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-bold tracking-tight leading-tight pb-4"
          style="font-family: 'Google Sans Flex', sans-serif;"
        >
          <span class="bg-gradient-to-br from-white via-zinc-100 to-zinc-400 bg-clip-text text-transparent">Navneet Dabral</span>
        </h1>
      </div>
      
      {/* Status Subtag */}
      <div class="flex items-center gap-2 px-4 py-1.5 rounded-full border border-white/10 bg-white/5 backdrop-blur-md mt-6 shadow-[0_0_30px_rgba(6,182,212,0.1)] animate-popIn relative z-10" style="animation-delay: 0.15s; animation-fill-mode: both;">
        <span class="w-2 h-2 rounded-full bg-cyan-400 animate-pulse shadow-[0_0_8px_rgba(6,182,212,0.8)]"></span>
        <p class="font-mono text-xs sm:text-sm text-zinc-300 tracking-wide uppercase">
         Full Stack Engineer
        </p>
      </div>
      
      <div class="flex flex-col items-center gap-6 max-w-2xl mx-auto px-4 mt-8 text-center animate-popIn relative z-10" style="animation-delay: 0.2s; animation-fill-mode: both;">
        <p class="text-base sm:text-lg md:text-xl text-zinc-300 leading-relaxed font-light tracking-wide max-w-xl">
          {years} years, {months} months of architecting frontend-heavy and full-stack web applications.
        </p>
        <p class="text-sm md:text-base text-zinc-400 leading-relaxed">
          I am a <strong class="text-zinc-200">product-focused engineer</strong> who brings a deep understanding of the entire software lifecycle. I specialize in bridging the gap between technical execution and business value, with proven expertise in driving complex products from the initial <span class="bg-gradient-to-r from-cyan-400 to-blue-500 bg-clip-text text-transparent font-medium">ideation phase</span> all the way to scalable <span class="bg-gradient-to-r from-purple-400 to-pink-500 bg-clip-text text-transparent font-medium">production systems</span>.
        </p>
      </div>
    </section>

    <div class="relative z-10 w-full mt-10">
      <Container client:load>
        <div class="flex flex-col w-full items-center">
          <section id="toolkit" class="w-full flex flex-col items-center" style="scroll-margin-top: 120px;">
            <p class="text-xs uppercase tracking-[0.2em] text-zinc-500 font-semibold mb-2">Capabilities</p>
            <h2 class="text-3xl md:text-5xl font-extrabold tracking-tighter" style="font-family: 'Google Sans Flex', sans-serif;">My Toolkit</h2>
            <Tech client:load />
          </section>

          <section id="experience" class="w-full flex flex-col items-center" style="scroll-margin-top: 120px;">
            <p class="text-xs uppercase tracking-[0.2em] text-zinc-500 font-semibold mb-2 mt-12 md:mt-24">Career Path</p>
            <h2 class="text-3xl md:text-5xl font-extrabold tracking-tighter mb-8" style="font-family: 'Google Sans Flex', sans-serif;">Work Experience</h2>
            <WorkExperience client:load />
          </section>
        </div>
      </Container>
    </div>
    
    <footer id="contact" class="relative w-full border-t border-white/5 bg-[#09090b] pt-16 pb-32 sm:pb-40 z-10 overflow-hidden text-center sm:text-left">
      {/* Background ambient corner glow entirely localized to footer */}
      <div class="absolute bottom-0 right-0 w-[400px] h-[400px] bg-cyan-500/10 mix-blend-screen filter blur-[100px] rounded-full pointer-events-none translate-y-1/2 translate-x-1/2 z-0"></div>

      <div class="max-w-7xl mx-auto px-6 lg:px-8 relative z-10">
        <div class="flex flex-col md:flex-row justify-between items-center md:items-start gap-12">
          
          <div class="flex flex-col max-w-sm">
            <h3 class="text-xl sm:text-2xl font-bold tracking-tighter text-zinc-100 flex items-center gap-2">
              <span class="w-3 h-3 rounded-full bg-cyan-400"></span>
              Navneet Dabral
            </h3>
            <p class="mt-4 text-sm text-zinc-400 leading-relaxed text-center sm:text-left">
              A product-focused engineer architecting high-performance web applications with modern tech stacks.
            </p>
          </div>

          <div class="flex flex-col md:items-end gap-6">
            <h4 class="text-xs font-semibold tracking-widest text-zinc-500 uppercase">Connect</h4>
            <div class="flex items-center gap-4">
              <a
                target="_blank"
                href="https://linkedin.com/in/navneet-dabral-859707117"
                rel="noopener noreferrer"
                class="group p-3 rounded-xl bg-white/5 border border-white/10 hover:bg-cyan-500/20 hover:border-cyan-500/30 hover:text-cyan-400 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_4px_20px_rgba(6,182,212,0.15)] text-zinc-400"
              >
                <IconBrandLinkedin size={24} stroke={1.5} client:load />
              </a>
              <a 
                target="_blank" 
                href="https://twitter.com/medabral" 
                rel="noopener noreferrer"
                class="group p-3 rounded-xl bg-white/5 border border-white/10 hover:bg-zinc-100 hover:text-zinc-900 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_4px_20px_rgba(255,255,255,0.15)] text-zinc-400"
              >
                <IconBrandX size={24} stroke={1.5} client:load />
              </a>
              <a 
                href="mailto:dabralnavneet@gmail.com" 
                title="Hire Me"
                class="group p-3 rounded-xl bg-white/5 border border-white/10 hover:bg-purple-500/20 hover:border-purple-500/30 hover:text-purple-400 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_4px_20px_rgba(168,85,247,0.15)] text-zinc-400"
              >
                <IconMail size={24} stroke={1.5} client:load />
              </a>
            </div>
            
            <a href="mailto:dabralnavneet@gmail.com" class="text-zinc-300 font-mono text-sm hover:text-cyan-400 transition-colors mt-2 pb-1 border-b border-white/10 hover:border-cyan-400 inline-block">
              dabralnavneet@gmail.com
            </a>
          </div>
        </div>

        <div class="mt-16 pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-4 text-zinc-500/80 text-xs font-mono">
          <p>
            © {new Date().getFullYear()} NAVNEET DABRAL. ALL RIGHTS RESERVED.
          </p>
          <p class="flex flex-wrap items-center justify-center md:justify-end gap-1">
            CRAFTED WITH <span class="text-cyan-400/80">ANTIGRAVITY</span>
          </p>
        </div>
      </div>
    </footer>
  </main>
</Layout>

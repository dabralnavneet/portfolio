---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Portfolio:: Navneet Dabral" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
    
    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Google Sans Flex (Display) -->
    <style>
      @font-face {
        font-family: 'Google Sans Flex';
        src: url('https://fonts.gstatic.com/s/googlesansflex/v16/t5t2IQcYNIWbFgDgAAzZ34auoVyXkJCOvp3SFWJbN5hF8LG572o.woff2') format('woff2');
        font-weight: 400 800;
        font-display: swap;
      }
    </style>
    
		<title>{title}</title>
	</head>
	<body class="font-sans antialiased bg-[#09090b] text-[#fafafa]">
		<slot />
	</body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
